{
  "manifest_version": 3,
  "name": "Sentinel: Threat Scan & Privacy Auditor",
  "version": "1.0.0",
  "description": "Scans the active site for phishing patterns, missing security headers, third-party trackers/cookies, and known-malicious domains.",
  "permissions": [
    "activeTab",
    "tabs",
    "webRequest",
    "cookies",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SiteGuard"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
